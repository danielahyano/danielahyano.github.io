---
// 1. Welcome to the Astro Frontmatter! 
const pageTitle = "dani's corner";
---
<script data-goatcounter="https://danielahyano.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">
  </head>
  <body>
    
    <main class="bento-container">
      
      <section class="bento-card profile-card">
        <h2>hello, i'm dani!</h2>
        <p>i am a physics phd student at rice university, analyzing lead-lead collisions with CERN's CMS experiment. my research focuses on charmonium production in ultraperipheral lead-lead collisions, probing gluon saturation in the nucleus.</p>
        <p>outside of work, i play table tennis (i am a former junior table tennis brazilian team member!), and have been learning how to crochet.</p>
      </section>

      <section class="bento-card nav-card">
        <h3>my journey</h3>
        <ul class="clean-list">
          <li>
            <strong>CERN</strong>
            <span class="sub-text">On-site Research (CMS Experiment), 2026–present</span>
          </li>
          <li>
            <strong>Rice University</strong>
            <span class="sub-text">PhD Physics, 2023–present</span>
          </li>
          <li>
            <strong>Barnard College</strong>
            <span class="sub-text">BA Physics &amp; CS, 2019–2023</span>
          </li>
        </ul>
      </section>

      <section class="bento-card nav-card">
        <h3>explore</h3>
        <ul class="bulleted-links">
          <li><a href="/lists">my board</a></li>
          <li><a href="/blog">stories, notes, thoughts</a></li>
          <li><a href="https://dcc.ligo.org/public/0183/T2200251/001/Yano_Daniela_final_report.pdf" target="_blank" rel="noopener noreferrer">LIGO Caltech 2023, final report</a></li>
        </ul>
      </section>

      <section class="bento-card nav-card">
        <h3>on the web</h3>
        <ul class="bulleted-links">
          <li><a href="https://news.rice.edu/news/2026/rice-table-tennis-club-advances-third-consecutive-national-championships-underscoring" target="_blank" rel="noopener noreferrer">(rice news) rice table tennis advances to nationals</a></li>
          <li><a href="https://physics.barnard.edu/news/physics-major-daniela-hikari-yano-23" target="_blank" rel="noopener noreferrer">(barnard news) Physics Major Daniela Hikari Yano ’23</a></li>
        </ul>
      </section>

      <section class="bento-card terminal-card">
        <div class="terminal-header">
          <div class="terminal-buttons">
            <span class="dot red"></span>
            <span class="dot yellow"></span>
            <span class="dot green"></span>
          </div>
          <span class="terminal-title">dani@-core:~</span>
        </div>
        
        <div class="terminal-body">
          <div class="terminal-log" id="terminal-log">
            <div>welcome to dani's core terminal v1.0.0</div>
            <div class="help-hint">type <span class="highlight">help</span> to view available system commands.</div>
          </div>
          
          <div class="terminal-input-line">
            <span class="terminal-prompt">dani@root:~$</span>
            <input type="text" id="terminal-input" autocomplete="off" autofocus placeholder="..." />
          </div>
        </div>
      </section>

      <section class="bento-card nav-card">
        <h3>contact me</h3>
        <ul class="bulleted-links">
          <li><a href="https://www.linkedin.com/in/daniela-yano/" target="_blank" rel="noopener noreferrer">linkedin</a></li>
          <li><a href="https://github.com/danielahyano?tab=repositories" target="_blank" rel="noopener noreferrer">github</a></li>
        </ul>
      </section>

    </main>

  </body>
</html>

<style>
  /* Global CSS Reset & Setup */
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: 'Space Mono', monospace;
    background-color: #f3e1e4; /* Beautiful soft pink palette choice */
    color: #1a1a1a;
    padding: 4rem 1rem 2rem 1rem;
    display: flex;
    justify-content: center;
    min-height: 100vh;
  }

  /* Bento Grid System */
  .bento-container {
    max-width: 1000px;
    width: 100%;
    display: grid;
    grid-template-columns: repeat(3, 1fr); 
    gap: 1.5rem;
  }

  /* Structural Card Designs */
  .bento-card {
    background-color: #ffffff;
    border: 3px solid #1a1a1a;
    padding: 1.5rem;
    box-shadow: 5px 5px 0px #1a1a1a;
    transition: transform 0.1s ease, box-shadow 0.1s ease;
  }

  .bento-card:hover {
    transform: translate(-2px, -2px);
    box-shadow: 7px 7px 0px #1a1a1a;
  }

  /* Card Grid Spans */
  .profile-card {
    grid-column: span 3;
  }

  .profile-card p {
    margin-top: 0.75rem;
    line-height: 1.5;
    font-size: 0.95rem;
  }

  .nav-card {
    grid-column: span 1;
  }

  .terminal-card {
    grid-column: span 2;
    background: #111827;
    color: #f3f4f6;
    border: 3px solid #1a1a1a;
    box-shadow: 5px 5px 0px #1a1a1a;
    padding: 0 !important;
    display: flex;
    flex-direction: column;
    height: 280px;
    overflow: hidden;
  }

  /* Typography formatting */
  h2, h3 {
    text-transform: lowercase;
    color: #1a1a1a;
  }

  h2 { font-size: 1.5rem; margin-bottom: 0.25rem; }
  h3 { font-size: 1.1rem; margin-bottom: 1rem; border-bottom: 2px dashed #e2e8f0; padding-bottom: 0.25rem;}

  /* List Architecture Formatting */
  .clean-list, .bulleted-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .clean-list strong {
    display: block;
    font-size: 0.9rem;
    color: #1a1a1a;
  }

  .sub-text {
    display: block;
    font-size: 0.8rem;
    color: #4b5563;
    margin-top: 0.1rem;
  }

/* 1. Reset list spacing */
  .bulleted-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  /* 2. Turn the list item into a flex row to align bullets nicely */
  .bulleted-links li {
    display: flex;
    align-items: flex-start; /* Keeps arrow aligned to top line if text wraps */
    gap: 0.5rem; /* Exact horizontal space between arrow and text */
    margin: 0;
    line-height: 1.4;
  }

  /* 3. The Custom Arrow Bullet */
  .bulleted-links li::before {
    content: "→";
    color: #1a1a1a;
    font-weight: bold;
    flex-shrink: 0; /* Prevents the arrow from squeezing on small screens */
  }

  /* 4. The Link Styles */
  .bulleted-links a {
    color: #4a6b5d; /* Your gorgeous muted retro-sage green */
    text-decoration: none;
    font-weight: bold;
    font-size: 0.9rem;
    display: inline;
    word-break: break-word; /* Ensures graceful wrap-arounds */
  }

  .bulleted-links a:hover {
    text-decoration: underline;
    color: #1a1a1a;
  }

  /* Terminal UI Window Components */
  .terminal-header {
    background: #e5e7eb;
    border-bottom: 3px solid #1a1a1a;
    padding: 0.6rem;
    display: flex;
    align-items: center;
    position: relative;
  }

  .terminal-buttons {
    display: flex;
    gap: 0.35rem;
  }

  .terminal-buttons .dot {
    width: 10px;
    height: 10px;
    border: 1.5px solid #1a1a1a;
    border-radius: 50%;
  }
  .dot.red { background: #ef4444; }
  .dot.yellow { background: #eab308; }
  .dot.green { background: #22c55e; }

  .terminal-title {
    color: #1a1a1a;
    font-size: 0.8rem;
    font-weight: bold;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  .terminal-body {
    padding: 1rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    font-size: 0.85rem;
    overflow-y: auto;
  }

  .terminal-log {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .help-hint {
    color: #9ca3af;
    font-size: 0.8rem;
  }

  .highlight {
    color: #a3e635; 
  }

  .terminal-input-line {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.4rem;
  }

  .terminal-prompt {
    color: #38bdf8;
    font-weight: bold;
  }

  #terminal-input {
    flex: 1;
    background: transparent;
    border: none;
    color: #ffffff;
    font-family: 'Space Mono', monospace;
    font-size: 0.85rem;
    outline: none;
  }

  /* Responsive media query styling layout structure */
  @media (max-width: 800px) {
    .bento-container {
      grid-template-columns: 1fr;
    }
    .profile-card, .nav-card, .terminal-card {
      grid-column: span 1 !important;
    }
    body {
      padding: 2rem 1rem;
    }
  }
</style>

<script is:inline>
  const termInput = document.getElementById('terminal-input');
  const termLog = document.getElementById('terminal-log');

  const commands = {
    help: "available commands: <br> • <span class='highlight'>about</span> - learn about my phd research<br> • <span class='highlight'>skills</span> - see my technical compute stack<br> • <span class='highlight'>clear</span> - flush the screen buffer",
    about: "dani is a physics ph.d. student at rice university working on high energy physics collisions at cern.",
    skills: "languages & frameworks: [python, c++, sql, astro, tailwind, linux]",
  };

  termInput.addEventListener('keydown', function(e) {
    if (e.key === 'Enter') {
      const inputVal = termInput.value.trim().toLowerCase();
      
      // Echo user command entry
      termLog.innerHTML += `<div class="terminal-input-line"><span class="terminal-prompt">dani@root:~$</span> <span>${inputVal}</span></div>`;
      
      // Run pipeline logical loops
      if (inputVal === 'clear') {
        termLog.innerHTML = '';
      } else if (inputVal in commands) {
        termLog.innerHTML += `<div>${commands[inputVal]}</div>`;
      } else if (inputVal === '') {
        // Do nothing for clean whitespace registers
      } else {
        termLog.innerHTML += `<div style="color: #ef4444;">bash: command not found: ${inputVal}. type <span class="highlight">help</span> for systems listing.</div>`;
      }
      
      termInput.value = '';
      const body = document.querySelector('.terminal-body');
      body.scrollTop = body.scrollHeight;
    }
  });
</script>
---
// src/pages/guestbook.astro
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>dani's live guestbook 🟢</title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
</head>
<body>

  <main class="page-container">
    <div class="nav-header">
      <a href="/" class="retro-btn">← go back home</a>
    </div>

    <section class="guestbook-container chat-style">
      <div class="chat-header">
        <h3>🟢 live guestbook chat</h3>
        <span class="chat-status">online</span>
      </div>

      <div class="guestbook-wall chat-history" id="guestbook-wall">
        </div>

      <form class="guestbook-form chat-input-bar" id="guestbook-form">
        <input type="text" id="name" placeholder="your name..." required class="chat-name-input" />
        <input type="text" id="message" placeholder="send a message..." required class="chat-msg-input" />
        
        <div class="chat-stamp-select">
          <select id="stamp-dropdown">
            <option value="🌟">🌟 star</option>
            <option value="❤️">❤️ heart</option>
            <option value="👻">👻 ghost</option>
            <option value="🐱">🐱 cat</option>
          </select>
        </div>
        <button type="submit" class="chat-send-btn">➔</button>
      </form>
    </section>
  </main>

<script is:inline>
  const SUPABASE_URL = "";
  const SUPABASE_KEY = "";

  const form = document.querySelector('.guestbook-form');
  const wall = document.querySelector('.guestbook-wall');

  // FETCH RECORDS\
  async function fetchEntries() {
    try {
      const response = await fetch(`${SUPABASE_URL}/rest/v1/guestbook?select=*&order=id.desc`, {
        headers: {
          "apikey": SUPABASE_KEY,
          "Authorization": `Bearer ${SUPABASE_KEY}`
        }
      });
      const entries = await response.json();
      
      entries.forEach(entry => {
        wall.innerHTML += `
          <div class="guestbook-entry">
            <div class="entry-header">
              <strong>${escapeHTML(entry.name)}</strong>
              <span class="entry-stamp">${escapeHTML(entry.stamp)}</span>
            </div>
            <p class="entry-text">${escapeHTML(entry.message)}</p>
          </div>
        `;
      });
    } catch (err) {
      console.error("Error loading guestbook:", err);
    }
  }

  // SUBMIT FORM (Updated to securely call our RPC function!)
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const name = document.getElementById('name').value;
    const message = document.getElementById('message').value;
    const stamp = document.querySelector('input[name="stamp"]:checked').value;
    
    const stampEmojis = { star: "🌟", heart: "❤️", ghost: "👻", cat: "🐱" };
    const chosenEmoji = stampEmojis[stamp] || "🌟";

    try {
      // Notice the URL change to /rpc/insert_guestbook_entry!
      const response = await fetch(`${SUPABASE_URL}/rest/v1/rpc/insert_guestbook_entry`, {
        method: 'POST',
        headers: {
          "apikey": SUPABASE_KEY,
          "Authorization": `Bearer ${SUPABASE_KEY}`,
          "Content-Type": "application/json"
        },
        body: JSON.stringify({ 
          p_name: name, 
          p_message: message, 
          p_stamp: chosenEmoji 
        })
      });

      if (response.ok) {
        form.reset();
        fetchEntries();
      } else {
        alert("Oops, something went wrong saving your entry!");
      }
    } catch (err) {
      console.error("Error submitting entry:", err);
    }
  });

  function escapeHTML(str) {
    return str.replace(/[&<>'"]/g, tag => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' }[tag] || tag));
  }

  fetchEntries();
</script>

</body>
</html>

<style>
  /* Base page setup matching your layout background */
  body {
    margin: 0;
    padding: 2rem;
    font-family: 'Space Mono', monospace;
    background-color: #e2e8f0; /* Matches your cool layout backdrop */
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .page-container {
    width: 100%;
    max-width: 650px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .nav-header {
    text-align: left;
  }

  .retro-btn {
    display: inline-block;
    font-family: 'Space Mono', monospace;
    font-size: 0.85rem;
    background: white;
    border: 2px solid #1a1a1a;
    padding: 6px 14px;
    text-decoration: none;
    color: black;
    box-shadow: 2px 2px 0px #1a1a1a;
    font-weight: bold;
  }

  /* The Chat Style Box styling rules we created earlier */
  .guestbook-container.chat-style {
    background-color: #f7fee7;
    border: 3px solid #1a1a1a;
    box-shadow: 4px 4px 0px #1a1a1a;
    display: flex;
    flex-direction: column;
    height: 480px; /* Upgraded height since it has its own page now! */
    overflow: hidden;
  }

  .chat-header {
    background-color: #d9f99d;
    border-bottom: 3px solid #1a1a1a;
    padding: 0.75rem 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .chat-header h3 { margin: 0; font-size: 1rem; }
  .chat-status { font-size: 0.75rem; background: #22c55e; color: white; padding: 2px 6px; border: 1.5px solid #1a1a1a; font-weight: bold; }

  .chat-history {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .guestbook-entry {
    background: #ffffff;
    border: 2px solid #1a1a1a;
    padding: 0.5rem 0.75rem;
    box-shadow: 2px 2px 0px #1a1a1a;
    border-radius: 4px;
    width: fit-content;
    max-width: 85%;
    text-align: left;
  }

  .entry-header { display: flex; align-items: center; gap: 0.5rem; font-size: 0.8rem; color: #4d7c0f; margin-bottom: 0.15rem; }
  .entry-text { font-size: 0.9rem; color: #1a1a1a; margin: 0; word-break: break-word; }

  .chat-input-bar {
    background: #ecfccb;
    border-top: 3px solid #1a1a1a;
    padding: 0.6rem;
    display: flex;
    gap: 0.5rem;
  }

  .chat-name-input { width: 120px !important; }
  .chat-msg-input { flex: 1; }
  .chat-name-input, .chat-msg-input, #stamp-dropdown {
    font-family: 'Space Mono', monospace;
    font-size: 0.85rem;